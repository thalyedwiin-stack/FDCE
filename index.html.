<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FDCE — Dashboard V1 · Pilotage des demandes</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');
  :root {
    --bg:#F4F3EF;--surface:#FFFFFF;--surface2:#F8F7F4;
    --border:rgba(0,0,0,0.08);--text:#1A1A18;--muted:#6B6B67;--hint:#9A9A96;
    --blue:#185FA5;--blue-l:#E6F1FB;--blue-m:#85B7EB;
    --green:#3B6D11;--green-l:#EAF3DE;--green-m:#97C459;
    --red:#A32D2D;--red-l:#FCEBEB;--red-m:#E24B4A;
    --amber:#633806;--amber-l:#FAEEDA;--amber-m:#EF9F27;
    --purple:#534AB7;--purple-l:#EEEDFE;--purple-m:#AFA9EC;
    --teal:#0F6E56;--teal-l:#E1F5EE;--teal-m:#1D9E75;
    --radius:10px;--radius-sm:6px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.5}
 
  /* TOPBAR */
  .topbar{background:var(--surface);border-bottom:0.5px solid var(--border);padding:0 24px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
  .topbar-left{display:flex;align-items:center;gap:10px}
  .logo-dot{width:10px;height:10px;border-radius:50%;background:var(--blue)}
  .logo-text{font-size:14px;font-weight:600;letter-spacing:-.3px}
  .v1-badge{font-size:10px;padding:2px 8px;border-radius:10px;background:var(--amber-l);color:var(--amber);font-weight:500}
  .topbar-right{display:flex;align-items:center;gap:6px}
  .pill{font-size:11px;padding:4px 12px;border-radius:20px;border:0.5px solid var(--border);background:var(--surface2);color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
  .pill:hover{background:var(--blue-l);color:var(--blue);border-color:var(--blue-m)}
  .pill.on{background:var(--blue-l);color:var(--blue);border-color:var(--blue-m);font-weight:500}
 
  /* PAGE */
  .page{padding:20px 24px;max-width:1400px;margin:0 auto}
 
  /* BANDEAU V1 */
  .v1-banner{background:var(--amber-l);border:0.5px solid #FAC775;border-radius:var(--radius-sm);padding:10px 16px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px;font-size:12px;color:var(--amber)}
  .v1-banner strong{font-weight:500}
 
  /* FAMILLES */
  .famille{margin-bottom:20px}
  .famille-header{display:flex;align-items:center;gap:8px;margin-bottom:10px;padding-bottom:6px;border-bottom:1.5px solid}
  .famille-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em}
  .famille-sub{font-size:11px;font-weight:400}
 
  .f-volumes .famille-header{border-color:var(--blue-m);color:var(--blue)}
  .f-delais  .famille-header{border-color:var(--purple-m);color:var(--purple)}
  .f-qualite .famille-header{border-color:var(--red-m);color:var(--red)}
  .f-charge  .famille-header{border-color:var(--teal-m);color:var(--teal)}
 
  /* KPI GRIDS */
  .kpi-row{display:grid;gap:10px;margin-bottom:12px}
  .kpi-row.col4{grid-template-columns:repeat(4,1fr)}
  .kpi-row.col3{grid-template-columns:repeat(3,1fr)}
  .kpi{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:12px 14px;transition:transform .15s}
  .kpi:hover{transform:translateY(-1px)}
  .kpi-label{font-size:10px;color:var(--muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em;line-height:1.4}
  .kpi-value{font-size:24px;font-weight:300;line-height:1;font-family:'DM Mono',monospace}
  .kpi-delta{font-size:10px;margin-top:5px}
  .up{color:var(--green)}.dn{color:var(--red)}.warn{color:var(--amber)}
 
  /* CARDS */
  .card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:14px 16px}
  .card-title{font-size:10px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
 
  /* GRIDS CHARTS */
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
  .grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px}
 
  /* BARS */
  .bar-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
  .bar-lbl{width:90px;font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bar-bg{flex:1;height:6px;border-radius:3px;background:var(--surface2)}
  .bar-fill{height:100%;border-radius:3px}
  .bar-val{width:34px;text-align:right;font-size:11px;font-weight:500;font-family:'DM Mono',monospace}
 
  /* EXEC */
  .exec-row{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:0.5px solid var(--border);font-size:11px}
  .exec-row:last-child{border-bottom:none}
  .av{width:24px;height:24px;border-radius:50%;background:var(--blue-l);color:var(--blue);font-size:9px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
 
  /* TABLE */
  .tbl{width:100%;border-collapse:collapse;font-size:11px;table-layout:fixed}
  .tbl th{padding:5px 8px;font-size:10px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;border-bottom:0.5px solid var(--border);text-align:left}
  .tbl td{padding:6px 8px;border-bottom:0.5px solid var(--border);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .tbl tr:last-child td{border-bottom:none}
  .tbl tr:hover td{background:var(--surface2)}
 
  /* BADGES */
  .badge{font-size:10px;padding:2px 7px;border-radius:6px;font-weight:500}
  .b-r{background:var(--red-l);color:var(--red)}
  .b-o{background:var(--amber-l);color:var(--amber)}
  .b-g{background:var(--green-l);color:var(--green)}
  .b-b{background:var(--blue-l);color:var(--blue)}
 
  /* LEG */
  .leg{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px}
  .li{display:flex;align-items:center;gap:4px;font-size:10px;color:var(--muted)}
  .ld{width:8px;height:8px;border-radius:2px;flex-shrink:0}
 
  /* ALERTE */
  .alert{background:var(--red-l);border:0.5px solid #F09595;border-radius:var(--radius-sm);padding:9px 14px;margin-bottom:14px;font-size:12px;color:var(--red);display:flex;align-items:center;gap:8px}
 
  /* BACKLOG NOTE */
  .backlog-note{background:var(--surface2);border:0.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 14px;margin-top:16px;font-size:11px;color:var(--muted);display:flex;gap:10px}
  .backlog-note strong{color:var(--text)}
 
  .footer{text-align:center;padding:20px;font-size:10px;color:var(--hint)}
 
  /* HEADER SEQENS */
  .header-seqens {
    width:100%;
    height:56px;
    background:#1B3A5C;
    display:flex;
    align-items:center;
    padding:0 28px;
    gap:16px;
  }
 
 
 
  .header-content {
    flex:1;
    display:flex;
    align-items:center;
    gap:16px;
  }
 
 
 
 
  .topbar { background: #1B3A5C !important; border-bottom: none !important; }
  .logo-text { color: #fff !important; }
  .v1-badge { background: rgba(255,255,255,0.15) !important; color: #fff !important; }
  .pill { border-color: rgba(255,255,255,0.25) !important; background: rgba(255,255,255,0.1) !important; color: rgba(255,255,255,0.8) !important; }
  .pill:hover { background: rgba(255,255,255,0.2) !important; color: #fff !important; }
  .pill.on { background: rgba(255,255,255,0.25) !important; color: #fff !important; border-color: rgba(255,255,255,0.5) !important; }
  .footer { background: #1B3A5C; color: rgba(255,255,255,0.7); text-align:center; padding:14px 24px; font-size:10px; margin-top:20px; }
  .footer strong { color: rgba(255,255,255,0.95); }
  .f-volumes .famille-header { border-color: #7BB8C4; color: #1B3A5C; }
  .f-charge .famille-header { border-color: #C8185A; color: #C8185A; }
</style>
</head>
<body>
 
<div class="header-seqens">
  <div style="display:flex;flex-direction:column;gap:3px;flex:1">
    <span style="font-size:18px;font-weight:400;color:#ffffff;letter-spacing:-.2px;line-height:1">Dashboard de pilotage FDCE</span>
    <span style="font-size:11px;color:rgba(255,255,255,0.6)">Suivi des demandes de contrat d'exploitation &nbsp;·&nbsp; <span style="background:rgba(255,255,255,0.15);padding:1px 8px;border-radius:10px;font-size:10px">V1 · À valider</span></span>
  </div>
  <div style="display:flex;align-items:center;gap:6px">
    <button class="pill" onclick="setPeriod(this)">T1</button>
    <button class="pill" onclick="setPeriod(this)">T2</button>
    <button class="pill" onclick="setPeriod(this)">T3</button>
    <button class="pill on" onclick="setPeriod(this)">T4</button>
    <button class="pill" onclick="window.print()">⎙ Imprimer</button>
  </div>
</div>
 
<div class="page">
 
  <div class="v1-banner">
    <span style="font-size:15px">📋</span>
    <span><strong>Version V1 — liste courte d'indicateurs à valider</strong> · Conclusions atelier du 03/06/2024 · Pilote : DEX (Zouhir) / DSI · Indicateurs restructurés en 4 familles : Volumes, Délais, Qualité, Charge · Liste complète à arbitrer au prochain atelier</span>
  </div>
 
  <div class="alert">
    ⚠ <span><strong>14 demandes</strong> dont la prise d'effet contrat est dans moins de 7 jours — action requise</span>
  </div>
 
  <!-- ═══════════════════════════════════════ -->
  <!-- FAMILLE 1 : VOLUMES -->
  <!-- ═══════════════════════════════════════ -->
  <div class="famille f-volumes">
    <div class="famille-header">
      <span class="famille-title">Volumes</span>
      <span class="famille-sub">— Combien de demandes, comment elles évoluent</span>
    </div>
 
    <div class="kpi-row col4">
      <div class="kpi">
        <div class="kpi-label">Total demandes / an (ind. 1)</div>
        <div class="kpi-value" style="color:var(--blue)">1 248</div>
        <div class="kpi-delta up">↑ +12% vs N-1</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Par thématique — top (ind. 2)</div>
        <div class="kpi-value" style="color:var(--blue)">Chauffage</div>
        <div class="kpi-delta" style="color:var(--muted)">28% des demandes</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Reçues ce mois (ind. 3)</div>
        <div class="kpi-value" style="color:var(--blue)">118</div>
        <div class="kpi-delta up">↑ +7 vs mois préc.</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Non traitées avant prise d'effet (ind. 7)</div>
        <div class="kpi-value" style="color:var(--red)">14</div>
        <div class="kpi-delta dn">⚠ Action requise</div>
      </div>
    </div>
 
    <div class="grid2">
      <div class="card">
        <div class="card-title">Évolution mensuelle — reçues vs traitées (ind. 1 & 3)</div>
        <div class="leg">
          <span class="li"><span class="ld" style="background:#85B7EB"></span>Reçues</span>
          <span class="li"><span class="ld" style="background:#97C459"></span>Traitées</span>
          <span class="li"><span class="ld" style="background:#E24B4A"></span>Hors délai</span>
        </div>
        <div style="position:relative;width:100%;height:180px">
          <canvas id="c-vol" role="img" aria-label="Volume mensuel">Données mensuelles.</canvas>
        </div>
      </div>
      <div class="card">
        <div class="card-title">Répartition par thématique (ind. 2)</div>
        <div class="leg" id="leg-th"></div>
        <div style="position:relative;width:100%;height:180px">
          <canvas id="c-th" role="img" aria-label="Répartition thématique">Données thématiques.</canvas>
        </div>
      </div>
    </div>
  </div>
 
  <!-- ═══════════════════════════════════════ -->
  <!-- FAMILLE 2 : DÉLAIS -->
  <!-- ═══════════════════════════════════════ -->
  <div class="famille f-delais">
    <div class="famille-header">
      <span class="famille-title">Délais</span>
      <span class="famille-sub">— Temps de traitement, SLA, étapes</span>
    </div>
 
    <div class="kpi-row col4">
      <div class="kpi">
        <div class="kpi-label">Délai moyen traitement (ind. 18)</div>
        <div class="kpi-value" style="color:var(--purple)">14,2 j</div>
        <div class="kpi-delta up">↓ -2j vs N-1</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">% dans le délai SLA (ind. 17)</div>
        <div class="kpi-value" style="color:var(--purple)">82%</div>
        <div class="kpi-delta up">SLA cible : 21j</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Temps correction → traité (ind. 10)</div>
        <div class="kpi-value" style="color:var(--purple)">3,2 j</div>
        <div class="kpi-delta warn">Étape la + longue / refus</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Hors délai — total (ind. 12)</div>
        <div class="kpi-value" style="color:var(--red)">105</div>
        <div class="kpi-delta dn">8,4% du total</div>
      </div>
    </div>
 
    <div class="grid2">
      <div class="card">
        <div class="card-title">SLA respecté par thématique (ind. 17)</div>
        <div id="sla-bars"></div>
      </div>
      <div class="card">
        <div class="card-title">Durée moyenne par étape (ind. 10 & 11)</div>
        <div style="position:relative;width:100%;height:180px">
          <canvas id="c-etapes" role="img" aria-label="Durée par étape">Données étapes.</canvas>
        </div>
      </div>
    </div>
  </div>
 
  <!-- ═══════════════════════════════════════ -->
  <!-- FAMILLE 3 : QUALITÉ -->
  <!-- ═══════════════════════════════════════ -->
  <div class="famille f-qualite">
    <div class="famille-header">
      <span class="famille-title">Qualité</span>
      <span class="famille-sub">— Renvois, corrections, refus, patrimoine</span>
    </div>
 
    <div class="kpi-row col4">
      <div class="kpi">
        <div class="kpi-label">Taux renvoi correction (ind. 13)</div>
        <div class="kpi-value" style="color:var(--red)">8,4%</div>
        <div class="kpi-delta dn">↑ +1,2pt vs N-1</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Moy. refus / demande (ind. 8)</div>
        <div class="kpi-value" style="color:var(--red)">0,3</div>
        <div class="kpi-delta" style="color:var(--hint)">Stable</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Demandes multi-corrigées (ind. 19)</div>
        <div class="kpi-value" style="color:var(--red)">54</div>
        <div class="kpi-delta dn">dont 13 avec 3+ corrections</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Patrimoine neuf — en attente &lt;3 mois (ind. 15)</div>
        <div class="kpi-value" style="color:var(--red)">38</div>
        <div class="kpi-delta dn">Prise d'effet proche</div>
      </div>
    </div>
 
    <div class="grid2">
      <div class="card">
        <div class="card-title">Demandes urgentes — 2 prochaines semaines (ind. rouge — prise d'effet contrat)</div>
        <table class="tbl">
          <thead>
            <tr>
              <th style="width:13%">Réf.</th>
              <th style="width:18%">Thématique</th>
              <th style="width:18%">Exécuteur</th>
              <th style="width:13%">Prise effet</th>
              <th style="width:10%">Jours</th>
              <th style="width:14%">Patrimoine</th>
              <th style="width:14%">Statut</th>
            </tr>
          </thead>
          <tbody id="tbl-body"></tbody>
        </table>
      </div>
      <div class="card">
        <div class="card-title">Répartition neuf vs existant par thématique (ind. 15 & 16 & 20)</div>
        <div style="position:relative;width:100%;height:200px">
          <canvas id="c-patri" role="img" aria-label="Patrimoine">Données patrimoine.</canvas>
        </div>
      </div>
    </div>
  </div>
 
  <!-- ═══════════════════════════════════════ -->
  <!-- FAMILLE 4 : CHARGE -->
  <!-- ═══════════════════════════════════════ -->
  <div class="famille f-charge">
    <div class="famille-header">
      <span class="famille-title">Charge</span>
      <span class="famille-sub">— Exécuteurs, demandeurs, pics de charge, territorialisation</span>
    </div>
 
    <div class="kpi-row col3">
      <div class="kpi">
        <div class="kpi-label">Exécuteur le + chargé (ind. 6)</div>
        <div class="kpi-value" style="color:var(--teal)">M. Laurent</div>
        <div class="kpi-delta" style="color:var(--muted)">87 demandes — 28%</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Demandeur le + actif (ind. 5)</div>
        <div class="kpi-value" style="color:var(--teal)">DEX Paris</div>
        <div class="kpi-delta" style="color:var(--muted)">142 demandes initiées</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Pic de charge — mois record</div>
        <div class="kpi-value" style="color:var(--teal)">Octobre</div>
        <div class="kpi-delta dn">125 demandes reçues</div>
      </div>
    </div>
 
    <div class="grid2">
      <div class="card">
        <div class="card-title">Charge par exécuteur — volume et avancement (ind. 6 & 14)</div>
        <div id="exec-list"></div>
      </div>
      <div class="card">
        <div class="card-title">Historique des pics de charge (ind. rouge)</div>
        <div style="position:relative;width:100%;height:180px">
          <canvas id="c-charge" role="img" aria-label="Pics de charge">Données charge.</canvas>
        </div>
      </div>
    </div>
  </div>
 
  <!-- NOTE BACKLOG -->
  <div class="backlog-note">
    <span style="font-size:16px">📌</span>
    <div>
      <strong>Sujets reportés au backlog lot 2</strong> (conclusions atelier 03/06/2024)<br>
      Extraction globale des données pour fichier bureautique · Besoins applicatifs connexes (motifs de refus, archivage) · Indicateur macro avec paramètres personnalisés · Stratégie reporting standard vs analyses ad hoc — à arbitrer avec la DSI
    </div>
  </div>
 
</div>
 
<div class="footer"><strong>Seqens · Groupe ActionLogement</strong> &nbsp;|&nbsp; FDCE — Dashboard de pilotage V1 &nbsp;|&nbsp; Pilote : DEX (Zouhir) / DSI &nbsp;|&nbsp; Prochain atelier : validation liste courte V1</div>
 
<script>
const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
 
new Chart(document.getElementById('c-vol'),{
  type:'bar',
  data:{labels:months,datasets:[
    {label:'Reçues',data:[82,91,78,105,112,98,74,65,110,125,118,90],backgroundColor:'#85B7EB',borderRadius:3,order:1},
    {label:'Traitées',data:[75,85,70,98,102,90,68,60,105,118,110,82],backgroundColor:'#97C459',borderRadius:3,order:2},
    {type:'line',label:'Hors délai',data:[7,9,5,12,10,8,6,5,9,14,12,8],borderColor:'#E24B4A',backgroundColor:'transparent',pointRadius:3,borderWidth:1.5,order:0,pointBackgroundColor:'#E24B4A'}
  ]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
    scales:{x:{ticks:{font:{size:9},autoSkip:false,maxRotation:0},grid:{display:false}},y:{ticks:{font:{size:9}},grid:{color:'rgba(0,0,0,0.04)'}}}}
});
 
const themes=['Chauffage','Eau/ECS','Électricité','Gaz','Ventilation','Ascenseurs','Autres'];
const thCols=['#378ADD','#1D9E75','#7F77DD','#EF9F27','#D85A30','#D4537E','#888780'];
const thData=[28,22,18,12,9,7,4];
const legTh=document.getElementById('leg-th');
themes.forEach((t,i)=>{legTh.innerHTML+=`<span class="li"><span class="ld" style="background:${thCols[i]}"></span>${t} ${thData[i]}%</span>`;});
new Chart(document.getElementById('c-th'),{type:'doughnut',data:{labels:themes,datasets:[{data:thData,backgroundColor:thCols,borderWidth:0,hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false,cutout:'62%',plugins:{legend:{display:false}}}});
 
const slaData=[{l:'Chauffage',v:82},{l:'Eau/ECS',v:91},{l:'Électricité',v:74},{l:'Gaz',v:88},{l:'Ventilation',v:61},{l:'Ascenseurs',v:95}];
const slaEl=document.getElementById('sla-bars');
slaData.forEach(d=>{const c=d.v>=80?'#639922':d.v>=65?'#EF9F27':'#E24B4A';slaEl.innerHTML+=`<div class="bar-row"><div class="bar-lbl">${d.l}</div><div class="bar-bg"><div class="bar-fill" style="width:${d.v}%;background:${c}"></div></div><div class="bar-val">${d.v}%</div></div>`;});
 
new Chart(document.getElementById('c-etapes'),{type:'bar',indexAxis:'y',
